  { src: '/images/photos/photo-22.jpg', alt: 'Aviation photo 22' },
  { src: '/images/photos/photo-23.jpg', alt: 'Aviation photo 23' },
  { src: '/images/photos/photo-24.jpg', alt: 'Aviation photo 24' },
