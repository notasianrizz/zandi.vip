---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Page Not Found">
  <div class="min-h-screen flex items-center justify-center text-center px-6">
    <div>
      <p class="font-mono text-[#38bdf8] text-8xl font-bold mb-2 opacity-30">404</p>
      <h1 class="text-3xl font-bold text-[#f1f5f9] mb-3">Lost in the clouds</h1>
      <p class="text-[#94a3b8] mb-8 max-w-sm mx-auto">
        This page doesn't exist. Let's get you back on course.
      </p>
      <a href="/" class="inline-flex items-center gap-2 bg-[#f59e0b] hover:bg-[#d97706] text-[#0a0f1e] font-semibold px-6 py-3 rounded-lg transition-colors text-sm">
        Return Home
      </a>
    </div>
  </div>
</BaseLayout>
